{
    "name": "condorcet-vote/cef-writer",
    "description": "Streaming PHP writer that produces valid Condorcet Election Format (CEF) files line by line.",
    "type": "library",
    "keywords": ["condorcet", "election", "cef", "voting", "writer", "streaming"],
    "require": {
        "php": "^8.5",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "pestphp/pest": "^4.7",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1",
        "julien-boudry/php-reference": "^0.7.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "CondorcetVote\\CefWriter\\": "src/"
        }
    },
    "scripts": {
        "test": "pest",
        "phpstan": "phpstan analyse",
        "linter": "php-cs-fixer fix"
    },
    "authors": [
        {
            "name": "Julien Boudry",
            "email": "julien@condorcet.vote"
        }
    ],
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
